<?xml version="1.0" ?>
<!--
  ketchup_placement_in_autosampler.sdf

  Gazebo world for HPLC workflow Step 8 (placement in the
  autosampler), ketchup case only. Mirrors the routine at:
    robotics-research/03-hplc-autosampler/03-hplc-workflow/
    08-placement-in-autosampler.md

  STEP 8 IN ONE SENTENCE
    Pick each finished, capped, labelled vial from the source
    rack and set it gently into its exact numbered slot in the
    autosampler tray, in the order the worklist demands.

  WHY THIS WORLD LOOKS THE WAY IT DOES
    - The tray sits ON THE BENCH, in an alignment plate, NOT
      inside the HPLC. This is exactly what the v1 spec calls
      for (see docs/hplc-autosamplers/requirements/00-spec-
      summary.md). The HPLC body is shown next to the bench
      for context but is DELIBERATELY outside the arm's reach
      envelope - we do not plan in-instrument reaches in v1.
    - The destination tray is the Agilent G2255A 100-position
      "classic" 10 x 10 grid. The source rack is the MicroSolv
      MV9502R-02B 50-well polypropylene rack. Both are pinned
      to specific reference products in the v1 spec.
    - Ketchup case = "hard case for tracking" - more vials than
      paracetamol. The worklist drives the placement order:
        Pos 1  = Blank        (solvent only, white cap)
        Pos 2  = Standard     (pure ref, blue cap)
        Pos 3  = Batch A r1   (red cap)
        Pos 4  = Batch A r2
        Pos 5  = Batch A r3
        Pos 6  = Batch B r1   (green cap)
        Pos 7  = Batch B r2
        Pos 8  = Batch B r3
        Pos 9  = Batch C r1   (orange cap)
        Pos 10 = Batch C r2
        Pos 11 = Batch C r3
        Pos 12 = Standard     (drift check, blue cap)
      = 12 capped+labelled vials sitting in the source rack
      waiting to be moved.

  NO ARM IS INCLUDED. A 2 mm yellow disc marks where the arm
  base will be bolted down (same convention as Steps 2/3/4/5).

  Units: SI. Metres, kilograms, radians. Bench top at z = 0.900 m.
-->
<sdf version="1.7">
  <world name="ketchup_placement_in_autosampler_cell">

    <light name="sun" type="directional">
      <cast_shadows>true</cast_shadows>
      <pose>0 0 10 0 0 0</pose>
      <diffuse>0.8 0.8 0.8 1</diffuse>
      <specular>0.2 0.2 0.2 1</specular>
      <attenuation>
        <range>1000</range>
        <constant>0.9</constant>
        <linear>0.01</linear>
        <quadratic>0.001</quadratic>
      </attenuation>
      <direction>-0.5 0.1 -0.9</direction>
    </light>

    <model name="ground_plane">
      <static>true</static>
      <link name="link">
        <collision name="c">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
        </collision>
        <visual name="v">
          <geometry><plane><normal>0 0 1</normal><size>100 100</size></plane></geometry>
          <material>
            <ambient>0.60 0.60 0.60 1</ambient>
            <diffuse>0.70 0.70 0.70 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <!-- Bench (top + 4 legs). Same shape and pose as Steps 2/3/4/5. -->
    <model name="bench">
      <static>true</static>
      <pose>0 0 0 0 0 0</pose>
      <link name="link">
        <visual name="top">
          <pose>0 0 0.875 0 0 0</pose>
          <geometry><box><size>0.60 1.00 0.05</size></box></geometry>
          <material><ambient>0.85 0.82 0.75 1</ambient><diffuse>0.85 0.82 0.75 1</diffuse></material>
        </visual>
        <collision name="top_c">
          <pose>0 0 0.875 0 0 0</pose>
          <geometry><box><size>0.60 1.00 0.05</size></box></geometry>
        </collision>
        <visual name="leg_fr">
          <pose>0.27 -0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
          <material><ambient>0.45 0.45 0.48 1</ambient><diffuse>0.60 0.60 0.63 1</diffuse></material>
        </visual>
        <collision name="leg_fr_c">
          <pose>0.27 -0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
        </collision>
        <visual name="leg_fl">
          <pose>0.27 0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
          <material><ambient>0.45 0.45 0.48 1</ambient><diffuse>0.60 0.60 0.63 1</diffuse></material>
        </visual>
        <collision name="leg_fl_c">
          <pose>0.27 0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
        </collision>
        <visual name="leg_br">
          <pose>-0.27 -0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
          <material><ambient>0.45 0.45 0.48 1</ambient><diffuse>0.60 0.60 0.63 1</diffuse></material>
        </visual>
        <collision name="leg_br_c">
          <pose>-0.27 -0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
        </collision>
        <visual name="leg_bl">
          <pose>-0.27 0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
          <material><ambient>0.45 0.45 0.48 1</ambient><diffuse>0.60 0.60 0.63 1</diffuse></material>
        </visual>
        <collision name="leg_bl_c">
          <pose>-0.27 0.47 0.425 0 0 0</pose>
          <geometry><cylinder><radius>0.025</radius><length>0.850</length></cylinder></geometry>
        </collision>
      </link>
    </model>

    <!-- Arm base marker - same position as Steps 2/3/4/5. -->
    <model name="arm_base_marker">
      <static>true</static>
      <pose>-0.22 0.00 0.901 0 0 0</pose>
      <link name="disc">
        <visual name="v">
          <geometry><cylinder><radius>0.05</radius><length>0.002</length></cylinder></geometry>
          <material><ambient>0.95 0.80 0.10 1</ambient><diffuse>0.95 0.80 0.10 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================
         HPLC instrument body: Agilent 1290 Infinity II Vialsampler
         (G7129B / G7129C), the v1 pinned reference instrument.
           Outer  : 324 (W, Y) x 396 (D, X) x 468 (H, Z) mm
           Mass   : 19 kg (static here)
         Sits behind the bench, on the lab floor, with its front
         face (the autosampler drawer) toward the technician (+X).
         Body center at world (-0.50, 0.00, 0.234). Front face is
         at X = -0.302, well behind the bench edge at X = -0.30.
         The body is OUTSIDE the arm's ~280 mm reach envelope by
         design: distance from arm marker (-0.22, 0, 0.901) to the
         nearest face of the HPLC = ~80 mm horizontal but 670 mm
         vertical below the bench top - and the drawer is closed
         during loading, so the arm physically cannot reach in.
         The autosampler drawer is shown closed (recessed band on
         the front face); the dark band marks where the loaded
         tray will slide in once the operator carries it over.
         ============================================================ -->
    <model name="hplc_instrument">
      <static>true</static>
      <pose>-0.50 0.00 0.234 0 0 0</pose>
      <link name="link">
        <!-- Main chassis (cream/grey enclosure) -->
        <visual name="chassis">
          <geometry><box><size>0.396 0.324 0.468</size></box></geometry>
          <material><ambient>0.88 0.86 0.82 1</ambient><diffuse>0.92 0.90 0.86 1</diffuse></material>
        </visual>
        <collision name="chassis_c">
          <geometry><box><size>0.396 0.324 0.468</size></box></geometry>
        </collision>
        <!-- Front face decoration: dark autosampler drawer band -->
        <visual name="drawer_band">
          <pose>0.199 0.00 0.000 0 0 0</pose>
          <geometry><box><size>0.002 0.280 0.110</size></box></geometry>
          <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.25 0.25 0.27 1</diffuse></material>
        </visual>
        <!-- Front face decoration: small green status LED -->
        <visual name="led">
          <pose>0.199 -0.130 0.180 0 0 0</pose>
          <geometry><box><size>0.002 0.010 0.005</size></box></geometry>
          <material>
            <ambient>0.10 0.80 0.20 1</ambient>
            <diffuse>0.15 0.95 0.25 1</diffuse>
            <emissive>0.05 0.40 0.10 1</emissive>
          </material>
        </visual>
        <!-- Front face decoration: model label strip -->
        <visual name="label_strip">
          <pose>0.199 0.000 0.210 0 0 0</pose>
          <geometry><box><size>0.002 0.180 0.020</size></box></geometry>
          <material><ambient>0.30 0.30 0.34 1</ambient><diffuse>0.35 0.35 0.40 1</diffuse></material>
        </visual>
        <!-- Top vent strip -->
        <visual name="top_vent">
          <pose>0.000 0.000 0.235 0 0 0</pose>
          <geometry><box><size>0.300 0.220 0.002</size></box></geometry>
          <material><ambient>0.55 0.55 0.58 1</ambient><diffuse>0.65 0.65 0.68 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================
         Alignment plate: a thin metal plate fixed to the bench
         that locates the autosampler tray to a known, calibrated
         position. The v1 spec demands +/-1 mm placement precision
         at the tray slot - the plate is how we recover that
         tolerance after the tray is slid in or out.
           Dimensions: 240 x 240 x 6 mm anodized aluminum
         Position centre on bench: (0.05, 0.00). Top of plate at
         z = 0.900 + 0.006 = 0.906 m.
         ============================================================ -->
    <model name="alignment_plate">
      <static>true</static>
      <pose>0.05 0.00 0.903 0 0 0</pose>
      <link name="link">
        <visual name="plate">
          <geometry><box><size>0.240 0.240 0.006</size></box></geometry>
          <material><ambient>0.55 0.57 0.60 1</ambient><diffuse>0.70 0.72 0.75 1</diffuse></material>
        </visual>
        <collision name="c">
          <geometry><box><size>0.240 0.240 0.006</size></box></geometry>
        </collision>
        <!-- Two raised locator pins (anti-rotation + corner registration) -->
        <visual name="pin_a">
          <pose>0.105 0.105 0.006 0 0 0</pose>
          <geometry><cylinder><radius>0.003</radius><length>0.008</length></cylinder></geometry>
          <material><ambient>0.30 0.30 0.32 1</ambient><diffuse>0.40 0.40 0.42 1</diffuse></material>
        </visual>
        <visual name="pin_b">
          <pose>-0.105 -0.105 0.006 0 0 0</pose>
          <geometry><cylinder><radius>0.003</radius><length>0.008</length></cylinder></geometry>
          <material><ambient>0.30 0.30 0.32 1</ambient><diffuse>0.40 0.40 0.42 1</diffuse></material>
        </visual>
        <!-- ArUco-style fiducial marker (white square + dark band) for
             visual servoing on the +/-1 mm slot tolerance. Per v1
             spec: "Rigid bench plate, levelled to +/-0.5 mm, ArUco
             fiducial near base". -->
        <visual name="fiducial_bg">
          <pose>-0.105 0.105 0.006 0 0 0</pose>
          <geometry><box><size>0.030 0.030 0.001</size></box></geometry>
          <material><ambient>0.98 0.98 0.98 1</ambient><diffuse>0.99 0.99 0.99 1</diffuse></material>
        </visual>
        <visual name="fiducial_fg">
          <pose>-0.105 0.105 0.0065 0 0 0</pose>
          <geometry><box><size>0.018 0.018 0.001</size></box></geometry>
          <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================
         Destination tray: Agilent G2255A 100-position "classic"
         autosampler tray.
           Outer  : 195 x 195 x 50 mm dark polymer block
           Layout : 10 x 10 grid, 18 mm pitch
           Slot   : Ø14 mm ID, ~1 mm radial clearance for a 12 mm
                    vial. ~32 mm deep, but we render only the visible
                    rim/sleeve here.
         Centre on alignment plate at (0.05, 0.00). Tray bottom at
         z = 0.906 (plate top), centre at z = 0.906 + 0.025 = 0.931.
         The tray is shown EMPTY because Step 8 is about placing
         vials INTO it - the vials start in the source rack and
         end here.
         ============================================================ -->
    <model name="destination_tray">
      <static>true</static>
      <pose>0.05 0.00 0.931 0 0 0</pose>
      <link name="link">
        <!-- Solid main block. Slot wells are not subtracted (Gazebo
             primitive limitation); the visible 10x10 of dark rim
             rings below are the operator's visual reference. -->
        <visual name="body">
          <geometry><box><size>0.195 0.195 0.050</size></box></geometry>
          <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.28 0.28 0.30 1</diffuse></material>
        </visual>
        <collision name="c">
          <geometry><box><size>0.195 0.195 0.050</size></box></geometry>
        </collision>
        <!-- Numbered-corner stripe (white) so the operator can tell
             which corner is "position 1". Real trays paint or laser-
             etch a "1" near a corner; we use a short white stripe. -->
        <visual name="corner_marker">
          <pose>-0.087 -0.087 0.026 0 0 0</pose>
          <geometry><box><size>0.020 0.020 0.001</size></box></geometry>
          <material><ambient>0.98 0.98 0.98 1</ambient><diffuse>0.99 0.99 0.99 1</diffuse></material>
        </visual>
        <!-- 10 x 10 visual slot grid: each cell is a thin dark
             cylinder showing the slot mouth. Pitch 18 mm; grid
             centred on the tray. Slot ID Ø14 mm; ring rendered as
             a flat disc Ø14 mm to show the operator's target. The
             100 slot-mouth visuals are listed compactly below. -->
        <!-- Row Y = -0.081 (j = 1) -->
        <visual name="slot_1_1"><pose>-0.081 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_2_1"><pose>-0.063 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_3_1"><pose>-0.045 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_4_1"><pose>-0.027 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_5_1"><pose>-0.009 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_6_1"><pose>0.009 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_7_1"><pose>0.027 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_8_1"><pose>0.045 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_9_1"><pose>0.063 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_10_1"><pose>0.081 -0.081 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <!-- Row Y = -0.063 (j = 2) -->
        <visual name="slot_1_2"><pose>-0.081 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_2_2"><pose>-0.063 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_3_2"><pose>-0.045 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_4_2"><pose>-0.027 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_5_2"><pose>-0.009 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_6_2"><pose>0.009 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_7_2"><pose>0.027 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_8_2"><pose>0.045 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_9_2"><pose>0.063 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_10_2"><pose>0.081 -0.063 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <!-- Row Y = -0.045 (j = 3) -->
        <visual name="slot_1_3"><pose>-0.081 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_2_3"><pose>-0.063 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_3_3"><pose>-0.045 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_4_3"><pose>-0.027 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_5_3"><pose>-0.009 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_6_3"><pose>0.009 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_7_3"><pose>0.027 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_8_3"><pose>0.045 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_9_3"><pose>0.063 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <visual name="slot_10_3"><pose>0.081 -0.045 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
        <!-- Row Y = -0.027 (j = 4) -->
        <visual name="slot_1_4"><pose>-0.081 -0.027 0.026 0 0 0</pose><geometry><cylinder><radius>0.007</radius><length>0.001</length></cylinder></geometry><material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.08 0.08 0.08 1</diffuse></material></visual>
