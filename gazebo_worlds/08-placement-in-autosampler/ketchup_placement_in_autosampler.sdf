        <visual name="body"><geometry><cylinder><radius>0.006</radius><length>0.032</length></cylinder></geometry><material><ambient>0.85 0.90 0.92 0.55</ambient><diffuse>0.85 0.90 0.92 0.55</diffuse></material></visual>
        <visual name="cap"><pose>0 0 0.020 0 0 0</pose><geometry><cylinder><radius>0.0065</radius><length>0.008</length></cylinder></geometry><material><ambient>0.98 0.98 0.98 1</ambient><diffuse>0.99 0.99 0.99 1</diffuse></material></visual>
        <visual name="label_band"><pose>0 0 -0.008 0 0 0</pose><geometry><cylinder><radius>0.00605</radius><length>0.004</length></cylinder></geometry><material><ambient>0.97 0.97 0.95 1</ambient><diffuse>0.99 0.99 0.97 1</diffuse></material></visual>
        <collision name="c"><geometry><cylinder><radius>0.006</radius><length>0.032</length></cylinder></geometry></collision>
      </link>
    </model>

