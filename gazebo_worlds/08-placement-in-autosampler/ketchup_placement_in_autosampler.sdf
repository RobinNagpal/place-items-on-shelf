          <pose>0 -0.020 0.0002 0 0 0</pose>
          <geometry><box><size>0.060 0.002 0.0001</size></box></geometry>
          <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.10 0.10 0.10 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================
         Barcode reader: small USB handheld scanner mounted on a
         vertical stand. Per the v1 spec, every vial barcode is read
         by the arm BEFORE placement to confirm the label matches
         the worklist's expected position.
           Stand base : 60 x 60 x 10 mm
           Stand neck : Ø12 x 100 mm
           Reader head: 80 x 50 x 40 mm angled scanner head, dark
                        plastic with a small red emissive window.
         Position: (0.20, -0.30).
         ============================================================ -->
    <model name="barcode_reader">
      <static>true</static>
      <pose>0.20 -0.30 0.900 0 0 0</pose>
      <link name="link">
        <visual name="base">
          <pose>0 0 0.005 0 0 0</pose>
          <geometry><box><size>0.060 0.060 0.010</size></box></geometry>
          <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.25 0.25 0.27 1</diffuse></material>
        </visual>
        <collision name="base_c">
          <pose>0 0 0.005 0 0 0</pose>
          <geometry><box><size>0.060 0.060 0.010</size></box></geometry>
        </collision>
        <visual name="neck">
          <pose>0 0 0.060 0 0 0</pose>
          <geometry><cylinder><radius>0.006</radius><length>0.100</length></cylinder></geometry>
          <material><ambient>0.30 0.30 0.32 1</ambient><diffuse>0.40 0.40 0.42 1</diffuse></material>
        </visual>
        <visual name="head">
          <pose>0.020 0 0.130 0 0.35 0</pose>
          <geometry><box><size>0.080 0.050 0.040</size></box></geometry>
          <material><ambient>0.18 0.18 0.20 1</ambient><diffuse>0.22 0.22 0.24 1</diffuse></material>
        </visual>
        <visual name="head_window">
          <pose>0.058 0 0.118 0 0.35 0</pose>
          <geometry><box><size>0.002 0.030 0.015</size></box></geometry>
          <material>
            <ambient>0.80 0.10 0.10 1</ambient>
            <diffuse>0.95 0.15 0.15 1</diffuse>
            <emissive>0.45 0.05 0.05 1</emissive>
          </material>
        </visual>
      </link>
    </model>

    <!-- ============================================================
         The twelve capped, labelled ketchup vials in the source rack.

         Each vial = 12 x 32 mm clear borosilicate body + Ø13 x 8 mm
         coloured screw cap + 12 x 4 mm coloured label band on the
         body. The body sleeves into the rack well; the cap and band
         show above the rack surface.

         Cap colour codes:
           white   = blank
           blue    = standard
           red     = batch A (3 replicates)
           green   = batch B (3 replicates)
           orange  = batch C (3 replicates)

         Rack-local well coordinates (rack centre at world
         (0.10, 0.32, 0.9125), rack X axis = bench X, Y axis = bench Y,
         well spacing 15 mm):
           Wells laid out as 5 (X) x 10 (Y).
           Used wells (well_X, well_Y) -> world position:
             1  (-2,  -4)  blank        world (0.070, 0.260)
             2  (-2,  -3)  standard     world (0.070, 0.275)
             3  (-2,  -2)  A_r1         world (0.070, 0.290)
             4  (-2,  -1)  A_r2         world (0.070, 0.305)
             5  (-2,   0)  A_r3         world (0.070, 0.320)
             6  (-2,  +1)  B_r1         world (0.070, 0.335)
             7  (-2,  +2)  B_r2         world (0.070, 0.350)
             8  (-2,  +3)  B_r3         world (0.070, 0.365)
             9  (-2,  +4)  C_r1         world (0.070, 0.380)
            10  (-1,  -4)  C_r2         world (0.085, 0.260)
            11  (-1,  -3)  C_r3         world (0.085, 0.275)
            12  (-1,  -2)  std drift    world (0.085, 0.290)

         All vials share the same height: bottom at z = 0.900,
         centre at z = 0.916, cap at z = 0.940 (32 + 8 mm above
         bench top, plus rack body just sleeves the bottom).
         ============================================================ -->

