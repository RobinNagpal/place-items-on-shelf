    <!-- ============================================================
         Source rack: MicroSolv MV9502R-02B 50-position polypropylene
         vial rack (the v1 pinned source rack).
           Outer  : 150 x 80 x 25 mm white PP block
           Layout : 10 (Y) x 5 (X) grid, 15 mm pitch
           Wells  : Ø14 mm ID, accept 12 x 32 mm vials with ~22 mm of
                    vial sleeved by the rack and the top ~10 mm + the
                    cap exposed above.
         Centre on bench: (0.10, 0.32). Rack bottom on the bench top,
         centre at z = 0.900 + 0.0125 = 0.9125.

         Twelve of the 50 wells are occupied by the capped, labelled
         ketchup vials that Step 8 will move. The remaining 38 wells
         are empty (just rack body shown; not modelled separately).
         ============================================================ -->
    <model name="source_rack">
      <static>true</static>
      <pose>0.10 0.32 0.9125 0 0 0</pose>
      <link name="link">
        <visual name="body">
          <geometry><box><size>0.080 0.150 0.025</size></box></geometry>
          <material><ambient>0.94 0.94 0.94 1</ambient><diffuse>0.98 0.98 0.98 1</diffuse></material>
        </visual>
        <collision name="c">
          <geometry><box><size>0.080 0.150 0.025</size></box></geometry>
        </collision>
        <!-- White "MV9502R" label strip on the long side. -->
        <visual name="label">
          <pose>0.0405 0.000 0.000 0 0 0</pose>
          <geometry><box><size>0.001 0.040 0.006</size></box></geometry>
          <material><ambient>0.20 0.20 0.22 1</ambient><diffuse>0.25 0.25 0.27 1</diffuse></material>
        </visual>
      </link>
    </model>

    <!-- ============================================================
         Worklist printout: a simple flat sheet of paper lying on the
         bench. Real workflows print or display the worklist next to
         the rack so the technician can map labels to positions one-
         to-one. Just a thin white rectangle here.
           Sheet : 100 x 70 x 0.2 mm white paper
         Position: (0.20, 0.32).
