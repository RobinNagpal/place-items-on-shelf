<?xml version="1.0"?>
<!--
  pos_robot v1 — mobile manipulator (Tier-2 build).

  Structure:
    base_link (diff-drive box) ── left_wheel, right_wheel, caster, tray_link
                              └── arm_column (vertical post, rear of base)
                                  └── arm_shoulder  (revolute, axis Y)
                                      └── arm_elbow   (revolute, axis Y)
                                          └── arm_wrist  (revolute, axis Y)
                                              └── gripper_base (fixed)
                                                  ├── left_finger  (prismatic +Y)
                                                  └── right_finger (prismatic -Y)

  Control: ros2_control + gz_ros2_control bridge + joint_trajectory_controller.
  Arm + gripper joints use the EFFORT command interface so the
  joint_trajectory_controller's PID can do proper torque-based motion
  (gravity is handled by the integral term) and the gripper can apply
  a real squeeze force on the can for friction-based grasping. The
  drive wheels are still driven by gz-sim's diff_drive plugin; they
  appear in <ros2_control> as state-only so joint_state_broadcaster
  publishes them too.

  This file is xacro — process it through xacro before passing to
  robot_state_publisher / Gazebo. The launch file does that.
-->
<robot name="pos_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ============================================================
       BASE  (heavier than before so the arm can't pitch it forward)
       ============================================================ -->
  <link name="base_link">
    <visual>
      <geometry><box size="0.5 0.4 0.15"/></geometry>
      <material name="blue"><color rgba="0.1 0.3 0.9 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.5 0.4 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="12.0"/>
      <inertia ixx="0.40" ixy="0" ixz="0" iyy="0.40" iyz="0" izz="0.50"/>
    </inertial>
  </link>

  <!-- ============================================================
       DRIVE WHEELS  (wheel separation 0.43, radius 0.05)
       ============================================================ -->
  <link name="left_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="0 0.215 -0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.03"/></geometry>
      <material name="black"><color rgba="0.1 0.1 0.1 1"/></material>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.05" length="0.03"/></geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.001" ixy="0" ixz="0" iyy="0.001" iyz="0" izz="0.001"/>
    </inertial>
  </link>
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.215 -0.025" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- ============================================================
       CASTER (front, fixed sphere — slides on ground)
       ============================================================ -->
  <link name="caster">
    <visual>
      <geometry><sphere radius="0.025"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <geometry><sphere radius="0.025"/></geometry>
    </collision>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001"/>
    </inertial>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster"/>
    <origin xyz="0.20 0 -0.05" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       ONBOARD TRAY
       ============================================================ -->
  <link name="tray_link">
    <visual>
      <geometry><box size="0.45 0.35 0.01"/></geometry>
      <material name="silver"><color rgba="0.8 0.8 0.85 1"/></material>
    </visual>
    <collision>
      <geometry><box size="0.45 0.35 0.01"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>
  <joint name="tray_joint" type="fixed">
    <parent link="base_link"/>
    <child link="tray_link"/>
    <origin xyz="0 0 0.08" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       ARM COLUMN  (stiffer + heavier than v1 to resist the moment
       from the cantilevered arm).
       ============================================================ -->
  <link name="arm_column">
    <visual>
      <origin xyz="0 0 0.20"/>
      <geometry><cylinder radius="0.035" length="0.40"/></geometry>
      <material name="grey"><color rgba="0.5 0.5 0.5 1"/></material>
    </visual>
    <collision>
      <origin xyz="0 0 0.20"/>
      <geometry><cylinder radius="0.035" length="0.40"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0.20"/>
      <mass value="2.0"/>
      <inertia ixx="0.05" ixy="0" ixz="0" iyy="0.05" iyz="0" izz="0.005"/>
    </inertial>
  </link>
  <joint name="arm_column_joint" type="fixed">
    <parent link="base_link"/>
    <child link="arm_column"/>
    <origin xyz="-0.15 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       ARM SHOULDER  (revolute, axis Y, link length 0.25 along +X)
       ============================================================ -->
  <link name="arm_shoulder">
    <visual>
      <origin xyz="0.125 0 0"/>
      <geometry><box size="0.25 0.045 0.045"/></geometry>
      <material name="orange"><color rgba="0.95 0.55 0.10 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.125 0 0"/>
      <geometry><box size="0.25 0.045 0.045"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.125 0 0"/>
      <mass value="0.30"/>
      <inertia ixx="0.0005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>
  <joint name="arm_shoulder_joint" type="revolute">
    <parent link="arm_column"/>
    <child link="arm_shoulder"/>
    <origin xyz="0 0 0.40" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.6" upper="1.6" effort="40" velocity="2.0"/>
    <dynamics damping="1.0"/>
  </joint>

  <!-- ============================================================
       ARM ELBOW  (revolute, axis Y, link length 0.20 along +X)
       ============================================================ -->
  <link name="arm_elbow">
    <visual>
      <origin xyz="0.10 0 0"/>
      <geometry><box size="0.20 0.04 0.04"/></geometry>
      <material name="orange"><color rgba="0.95 0.55 0.10 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.10 0 0"/>
      <geometry><box size="0.20 0.04 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.10 0 0"/>
      <mass value="0.20"/>
      <inertia ixx="0.0002" ixy="0" ixz="0" iyy="0.002" iyz="0" izz="0.002"/>
    </inertial>
  </link>
  <joint name="arm_elbow_joint" type="revolute">
    <parent link="arm_shoulder"/>
    <child link="arm_elbow"/>
    <origin xyz="0.25 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.5" upper="2.5" effort="30" velocity="2.0"/>
    <dynamics damping="0.8"/>
  </joint>

  <!-- ============================================================
       ARM WRIST  (revolute, axis Y, link length 0.05 along +X)
       ============================================================ -->
  <link name="arm_wrist">
    <visual>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.04 0.04"/></geometry>
      <material name="orange"><color rgba="0.95 0.55 0.10 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.04 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.025 0 0"/>
      <mass value="0.08"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>
  <joint name="arm_wrist_joint" type="revolute">
    <parent link="arm_elbow"/>
    <child link="arm_wrist"/>
    <origin xyz="0.20 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-2.0" upper="2.0" effort="20" velocity="2.0"/>
    <dynamics damping="0.5"/>
  </joint>

  <!-- ============================================================
       GRIPPER BASE (palm)  — fixed to the wrist
       ============================================================ -->
  <link name="gripper_base">
    <visual>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.06 0.04"/></geometry>
      <material name="dark_grey"><color rgba="0.25 0.25 0.25 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.025 0 0"/>
      <geometry><box size="0.05 0.06 0.04"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.025 0 0"/>
      <mass value="0.10"/>
      <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0005" iyz="0" izz="0.0005"/>
    </inertial>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="arm_wrist"/>
    <child link="gripper_base"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================
       GRIPPER FINGERS  (prismatic, mirror pair)
       Joint position is the distance of the finger from the gripper
       centerline. Range 0.005 (closed) .. 0.045 (fully open).
       Soda can radius = 0.033, so for a friction grasp we command
       both fingers to overshoot inward (e.g., 0.020) — joint can't
       reach the target because the can is in the way, and the
       trajectory PID accumulates the position error into a sustained
       squeeze effort (up to the joint's effort limit). Real fingers
       work the same way.
       ============================================================ -->
  <link name="left_finger">
    <visual>
      <origin xyz="0.03 0 0"/>
      <geometry><box size="0.06 0.005 0.05"/></geometry>
      <material name="dark_grey"><color rgba="0.25 0.25 0.25 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.03 0 0"/>
      <geometry><box size="0.06 0.005 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.03 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  <joint name="left_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="left_finger"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="0.005" upper="0.045" effort="40" velocity="0.2"/>
    <dynamics damping="3.0"/>
  </joint>

  <link name="right_finger">
    <visual>
      <origin xyz="0.03 0 0"/>
      <geometry><box size="0.06 0.005 0.05"/></geometry>
      <material name="dark_grey"><color rgba="0.25 0.25 0.25 1"/></material>
    </visual>
    <collision>
      <origin xyz="0.03 0 0"/>
      <geometry><box size="0.06 0.005 0.05"/></geometry>
    </collision>
    <inertial>
      <origin xyz="0.03 0 0"/>
      <mass value="0.02"/>
      <inertia ixx="0.00001" ixy="0" ixz="0" iyy="0.00005" iyz="0" izz="0.00005"/>
    </inertial>
  </link>
  <joint name="right_finger_joint" type="prismatic">
    <parent link="gripper_base"/>
    <child link="right_finger"/>
    <origin xyz="0.05 0 0" rpy="0 0 0"/>
    <axis xyz="0 -1 0"/>
    <limit lower="0.005" upper="0.045" effort="40" velocity="0.2"/>
    <dynamics damping="3.0"/>
  </joint>

  <!-- ============================================================
       ros2_control HARDWARE BLOCK
       Arm: POSITION command interface. gz_ros2_control writes the
       commanded joint position directly each control step; JTC's
       trajectory interpolation at 100 Hz makes that visually smooth
       AND removes the need to tune effort-PID gains against gravity
       (the earlier effort setup oscillated at the velocity limit).
       Gripper: EFFORT command interface. Needed so the finger PID
       can apply a sustained squeeze force against the can — position
       interface would teleport the fingers through the can.
       Wheels: NOT listed here. The diff_drive plugin owns their
       commands; joint_state_broadcaster therefore won't publish
       wheel state and the visual wheels will not appear to rotate.
       That's fine for v1 — the robot still translates.
       ============================================================ -->
  <ros2_control name="GazeboSimSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <joint name="arm_shoulder_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="arm_elbow_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="arm_wrist_joint">
      <command_interface name="position"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="left_finger_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
    <joint name="right_finger_joint">
      <command_interface name="effort"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>
  </ros2_control>

  <!-- ============================================================
       GAZEBO PLUGINS
       ============================================================ -->
  <gazebo>
    <!-- gz_ros2_control: hosts the controller_manager + all controllers
         in-process inside Gazebo. The <parameters> path is resolved by
         xacro at launch time to an absolute share/.../config/controllers.yaml. -->
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find pos_v1_bringup)/config/controllers.yaml</parameters>
    </plugin>

    <!-- Diff-drive base: still driven by gz-sim, not ros2_control. -->
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.43</wheel_separation>
      <wheel_radius>0.05</wheel_radius>
      <odom_publish_frequency>30</odom_publish_frequency>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>

    <!-- NOTE: gz-sim-joint-state-publisher REMOVED.
         joint_state_broadcaster (in controllers.yaml) publishes /joint_states
         covering both the diff-drive wheels (state-only) and the arm+gripper. -->
  </gazebo>

  <!-- Low friction on caster so the fixed sphere doesn't resist turning. -->
  <gazebo reference="caster">
    <mu1>0.05</mu1>
    <mu2>0.05</mu2>
  </gazebo>

  <!-- High friction on finger pads so the gripper can hold the can. -->
  <gazebo reference="left_finger">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1e6</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>
  <gazebo reference="right_finger">
    <mu1>2.0</mu1>
    <mu2>2.0</mu2>
    <kp>1e6</kp>
    <kd>100.0</kd>
    <minDepth>0.001</minDepth>
  </gazebo>

</robot>
